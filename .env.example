# Google Cloud / Vertex AI
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_REGION=global
# Chỉ cần khi STT chạy bằng Google (VIDEO_DUB_STT_ENGINE=google).
VIDEO_DUB_GCS_BUCKET=your-stt-bucket

# Models
VIDEO_DUB_GEMINI_MODEL=gemini-2.5-flash
VIDEO_DUB_TTS_MODEL=gemini-2.5-flash-tts

# Tạo giọng (TTS) mặc định cho job KHÔNG tự đặt riêng: gemini (cloud Vertex AI, mặc
# định) | vieneu (local, miễn phí, cần cài backend/requirements-tts-local.txt).
# Từng job có thể override qua PATCH /api/jobs/{id} {"tts_engine": "vieneu"|"gemini"}
# (không có trên UI) để chạy song song nhiều job với engine khác nhau.
VIDEO_DUB_TTS_ENGINE=gemini
# Giọng preset VieNeu (vd Ngọc Lan, Xuân Vĩnh); để trống dùng giọng mặc định của model.
VIDEO_DUB_VIENEU_VOICE=
# File wav 3-5 giây để nhân bản giọng; nếu đặt sẽ ưu tiên hơn VIDEO_DUB_VIENEU_VOICE.
VIDEO_DUB_VIENEU_REF_AUDIO=

# Nhận dạng giọng nói (STT): whisper (local, mặc định) | google (STT V2 batch qua GCS)
VIDEO_DUB_STT_ENGINE=whisper
VIDEO_DUB_WHISPER_MODEL=medium
VIDEO_DUB_WHISPER_COMPUTE=int8

# Tách thoại/nền: htdemucs (mặc định) | htdemucs_ft (sạch hơn, chậm hơn)
VIDEO_DUB_DEMUCS_MODEL=htdemucs
# Số lần shift khi tách (0 = nhanh; 2-5 = sạch hơn, chậm hơn)
VIDEO_DUB_DEMUCS_SHIFTS=0

# true: chạy UI/API bằng dữ liệu mô phỏng, không gọi Cloud.
# false/để trống: tự dùng pipeline thật khi đủ FFmpeg + Cloud config.
VIDEO_DUB_DEMO_MODE=auto

# Số đoạn TTS tạo song song lúc export + giãn cách tối thiểu (giây) giữa các lần gọi.
# Mặc định 2 worker / 8s an toàn cho quota free/promo tier. Nếu project đã bật billing
# với quota TTS trả phí bình thường, có thể tăng lên để export nhanh hơn (vd 4 / 2).
# Tăng quá cao so với quota thật sẽ gây lỗi 429 giữa chừng export.
VIDEO_DUB_TTS_WORKERS=2
VIDEO_DUB_TTS_MIN_INTERVAL=8
