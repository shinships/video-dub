# Google Cloud / Vertex AI
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_REGION=global
# Chỉ cần khi STT chạy bằng Google (VIDEO_DUB_STT_ENGINE=google).
VIDEO_DUB_GCS_BUCKET=your-stt-bucket

# Model Gemini cho bước DỊCH (Vertex AI). TTS không dùng Gemini nữa.
VIDEO_DUB_GEMINI_MODEL=gemini-2.5-flash

# Tạo giọng (TTS) mặc định cho job KHÔNG tự đặt riêng: vieneu (local, miễn phí, mặc
# định, cần cài backend/requirements-tts-local.txt) | vbee (cloud VN, giọng tiếng Việt
# tự nhiên, cần App ID + token studio Vbee). Gemini TTS đã bị loại bỏ.
# Từng job có thể override qua PATCH /api/jobs/{id} {"tts_engine": "vieneu"|"vbee"}.
VIDEO_DUB_TTS_ENGINE=vieneu
# Vbee TTS — App ID và token lấy trong studio Vbee. voiceCode xem danh sách qua API voices
# (vd hn_female_ngochuyen_full_48k-fhg, sg_male_minhhoang_full_48k-fhg).
VIDEO_DUB_VBEE_APP_ID=
VIDEO_DUB_VBEE_TOKEN=
VIDEO_DUB_VBEE_VOICE=hn_female_ngochuyen_full_48k-fhg
# Giọng preset VieNeu (vd Ngọc Lan, Xuân Vĩnh); để trống dùng giọng mặc định của model.
VIDEO_DUB_VIENEU_VOICE=
# File wav 3-5 giây để nhân bản giọng; nếu đặt sẽ ưu tiên hơn VIDEO_DUB_VIENEU_VOICE.
VIDEO_DUB_VIENEU_REF_AUDIO=
# cpu (mặc định, an toàn) | cuda. VieNeu tự dò CUDA của torch (cài cho Demucs) và có
# thể đụng cuDNN thiếu symbol tuỳ máy — chỉ đổi cuda nếu đã xác nhận ổn định.
VIDEO_DUB_VIENEU_DEVICE=cpu

# --- Lồng tiếng 2 giọng (nam/nữ) ---
# Bật tự dò giới tính người nói theo cao độ (F0) trên vocals.wav rồi gán giọng riêng cho mỗi
# đoạn. Mặc định tắt (1 giọng như cũ). Bật riêng từng job qua công tắc lúc upload, cờ CLI
# --multi-speaker, hoặc PATCH /api/jobs/{id} {"multi_speaker": true}.
VIDEO_DUB_MULTI_SPEAKER=false
# Ngưỡng Hz phân nam/nữ (F0 dưới -> nam, bằng/trên -> nữ). Mặc định 165 hợp phần lớn giọng.
VIDEO_DUB_GENDER_F0_THRESHOLD=165
# Giọng theo giới tính khi bật multi_speaker. Giọng NAM để trống thì kế thừa cấu hình 1-giọng
# ở trên (VBEE_VOICE / VIENEU_VOICE / VIENEU_REF_AUDIO) nên thường chỉ cần khai thêm giọng NỮ.
VIDEO_DUB_VBEE_VOICE_MALE=
VIDEO_DUB_VBEE_VOICE_FEMALE=hn_female_ngochuyen_full_48k-fhg
VIDEO_DUB_VIENEU_VOICE_MALE=
VIDEO_DUB_VIENEU_REF_AUDIO_MALE=
VIDEO_DUB_VIENEU_VOICE_FEMALE=
VIDEO_DUB_VIENEU_REF_AUDIO_FEMALE=

# Nhận dạng giọng nói (STT): whisper (local, mặc định) | google (STT V2 batch qua GCS)
VIDEO_DUB_STT_ENGINE=whisper
VIDEO_DUB_WHISPER_MODEL=medium
VIDEO_DUB_WHISPER_COMPUTE=int8

# Tách thoại/nền: htdemucs (mặc định) | htdemucs_ft (sạch hơn, chậm hơn)
VIDEO_DUB_DEMUCS_MODEL=htdemucs
# Số lần shift khi tách (0 = nhanh; 2-5 = sạch hơn, chậm hơn)
VIDEO_DUB_DEMUCS_SHIFTS=0

# true: chạy UI/API bằng dữ liệu mô phỏng, không gọi Cloud.
# false/để trống: tự dùng pipeline thật khi đủ FFmpeg + Cloud config.
VIDEO_DUB_DEMO_MODE=auto

# Số đoạn TTS tạo song song lúc export. VieNeu chạy local (tuỳ CPU/GPU); Vbee gọi cloud
# bất đồng bộ. Tăng để export nhanh hơn nếu máy/khoản Vbee chịu được.
VIDEO_DUB_TTS_WORKERS=2
